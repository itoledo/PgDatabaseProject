<Window x:Class="PgDatabaseProject.Extension.Dialogs.ImportWizardDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        Title="Import PostgreSQL Database"
        Height="520" Width="600"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" FontSize="16" FontWeight="SemiBold"
                   Margin="0,0,0,12" Text="{Binding StepTitle}" />

        <!-- Step Content -->
        <Grid Grid.Row="1">
            <!-- Step 1: Connection -->
            <Grid Visibility="{Binding IsStep1Visible}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Host:" VerticalAlignment="Center" Margin="0,4"/>
                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Host, UpdateSourceTrigger=PropertyChanged}" Margin="0,4"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Port:" VerticalAlignment="Center" Margin="0,4"/>
                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}" Margin="0,4"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Database:" VerticalAlignment="Center" Margin="0,4"/>
                <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Database, UpdateSourceTrigger=PropertyChanged}" Margin="0,4"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Username:" VerticalAlignment="Center" Margin="0,4"/>
                <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" Margin="0,4"/>

                <TextBlock Grid.Row="4" Grid.Column="0" Text="Password:" VerticalAlignment="Center" Margin="0,4"/>
                <PasswordBox Grid.Row="4" Grid.Column="1" x:Name="PasswordBox" Margin="0,4"/>

                <TextBlock Grid.Row="5" Grid.Column="0" Text="SSL Mode:" VerticalAlignment="Center" Margin="0,4"/>
                <ComboBox Grid.Row="5" Grid.Column="1" SelectedItem="{Binding SslMode}" Margin="0,4">
                    <sys:String>Prefer</sys:String>
                    <sys:String>Require</sys:String>
                    <sys:String>Disable</sys:String>
                </ComboBox>

                <Button Grid.Row="6" Grid.Column="1" Content="Test Connection"
                        Command="{Binding TestConnectionCommand}" Margin="0,8,0,0"
                        HorizontalAlignment="Left" Padding="16,4"/>

                <TextBlock Grid.Row="7" Grid.Column="1" Text="{Binding ConnectionStatus}"
                           Foreground="{Binding ConnectionStatusColor}" Margin="0,4"/>
            </Grid>

            <!-- Step 2: Object Selection -->
            <Grid Visibility="{Binding IsStep2Visible}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Select schemas and object types to import:" Margin="0,0,0,8"/>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <GroupBox Grid.Column="0" Header="Schemas" Margin="0,0,4,0">
                        <ListBox ItemsSource="{Binding AvailableSchemas}" Margin="4">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox Content="{Binding Name}" IsChecked="{Binding IsSelected}"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </GroupBox>

                    <GroupBox Grid.Column="1" Header="Object Types" Margin="4,0,0,0">
                        <ListBox ItemsSource="{Binding AvailableObjectTypes}" Margin="4">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox Content="{Binding Name}" IsChecked="{Binding IsSelected}"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </GroupBox>
                </Grid>

                <CheckBox Grid.Row="2" Content="Include DROP IF EXISTS statements"
                          IsChecked="{Binding IncludeDropIfExists}" Margin="0,8,0,0"/>

                <CheckBox Grid.Row="3" Content="Overwrite existing files"
                          IsChecked="{Binding OverwriteExisting}" Margin="0,4,0,0"/>
            </Grid>

            <!-- Step 3: Progress -->
            <Grid Visibility="{Binding IsStep3Visible}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <ProgressBar Grid.Row="0" Height="24" Minimum="0" Maximum="100"
                             Value="{Binding ProgressValue}" Margin="0,0,0,8"/>

                <TextBlock Grid.Row="1" Text="{Binding ProgressText}" Margin="0,0,0,8"/>

                <ListBox Grid.Row="2" ItemsSource="{Binding LogMessages}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" FontFamily="Consolas" FontSize="11"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Grid>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="&lt; Back" Command="{Binding BackCommand}"
                    Width="80" Margin="0,0,8,0" Padding="4"/>
            <Button Content="{Binding NextButtonText}" Command="{Binding NextCommand}"
                    Width="80" Margin="0,0,8,0" Padding="4"/>
            <Button Content="Cancel" IsCancel="True"
                    Width="80" Padding="4"/>
        </StackPanel>
    </Grid>
</Window>
